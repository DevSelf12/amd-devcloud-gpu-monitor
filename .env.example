# AMD Dev Cloud GPU Stock Monitor — Environment Config
# Copy this to .env and fill in your values

# Telegram Bot API (create bot via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AMD Dev Cloud API endpoint (capture from browser DevTools)
# Open devcloud.amd.com → F12 → Network → XHR → find the availability request
AMD_ENDPOINT=https://devcloud.amd.com/api/machines

# Cookie file path (export from browser)
COOKIE_FILE=cookies.json

# Check interval in seconds
CHECK_INTERVAL=60
